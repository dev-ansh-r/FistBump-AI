{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Rocky default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/rocky-backend",
          "sidecar": true,
          "args": ["--port", "6070"]
        }
      ]
    }
  ]
}
